NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (never NEXT_PUBLIC): evaluator persistence + admin flows
SUPABASE_SERVICE_ROLE_KEY=

# LLM + voice providers. GROQ_API_KEY serves chat LLMs (default provider),
# Whisper STT, and Orpheus TTS. ANTHROPIC_API_KEY is only needed when rolling
# back with LLM_PROVIDER=anthropic (per-role overrides: see src/lib/llm/config.ts).
GROQ_API_KEY=
ANTHROPIC_API_KEY=
# LLM_PROVIDER=anthropic
# ELEVENLABS_API_KEY=   # optional TTS A/B only
